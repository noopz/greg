{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "entry": ["src/**/*.ts", "tests/**/*.test.ts"],
  "project": ["src/**/*.ts", "tests/**/*.test.ts"],

  "ignoreDependencies": [
    "debug",
    "bun-types"
  ],

  "ignoreBinaries": [
    "claude"
  ],

  "ignoreExportsUsedInFile": true,

  "includeEntryExports": true,

  "tags": ["-internal"]
}
