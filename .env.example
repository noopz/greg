# Discord selfbot token (extract from browser DevTools > Network tab > Authorization header)
DISCORD_TOKEN=

# Your Discord user ID (receives audit trail DMs for bot actions)
CREATOR_USER_ID=

# Bot display name (used in prompts, logs, and identity strings)
BOT_NAME=Greg

# Comma-separated Discord channel IDs to watch (DM + group DM)
# The bot auto-detects channel types and sets aliases (dm, group, primary)
CHANNEL_IDS=

# Klipy API key for GIF/sticker/meme search (get at partner.klipy.com/api-keys)
# Free API - powers Discord, Canva, Figma, etc.
KLIPY_API_KEY=

# Steam integration (optional — enables Steam library lookups for game picker)
# Run local/plugins/steam-game-picker/scripts/setup.ts to generate the refresh token
STEAM_REFRESH_TOKEN=
STEAM_SHARED_SECRET=

# Enable image vision (set to "1" to allow the bot to see image attachments)
ENABLE_IMAGES=

# Logging options
LOG_TO_FILE=true          # Set to "false" to disable file logging
LOG_MAX_SIZE_MB=50        # Max log file size before rotation
